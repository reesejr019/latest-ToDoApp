{
  "name": "todoapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "predeploy": "expo export --platform web && node -e \"const fs=require('fs');let h=fs.readFileSync('dist/index.html','utf8');h=h.replace(/href=\\\"\\\//g,'href=\\\"./').replace(/src=\\\"\\\//g,'src=\\\"./');fs.writeFileSync('dist/index.html',h);\"",
    "deploy": "gh-pages -d dist --nojekyll"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@rneui/base": "^5.0.0",
    "@rneui/themed": "^5.0.0",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-web": "^0.21.2"
  },
  "private": true,
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
